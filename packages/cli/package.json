{
  "name": "@fetchkit/cli",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "fetchkit": "./dist/index.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@fetchkit/brand": "workspace:*",
    "@fetchkit/legal": "workspace:*",
    "@fetchkit/seo": "workspace:*",
