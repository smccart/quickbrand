    "directory": "packages/cli"
  },
  "homepage": "https://fetchkit.dev",
  "license": "MIT",
  "keywords": ["scaffolding", "cli", "brand", "legal", "seo", "security", "developer-tools", "ai-agent", "llm", "automation"],
