{
  "name": "@fetchkit/brand",
  "version": "0.1.0",
  "description": "Brand identity generator for developers and AI agents — logos, favicons, palettes, design tokens, letterheads, and more. Callable via REST API, MCP server, or direct import.",
  "license": "MIT",
  "repository": { "type": "git", "url": "https://github.com/smccart/fetchkit", "directory": "packages/brand" },
  "homepage": "https://fetchkit.dev",
  "keywords": ["brand", "logo", "favicon", "design-tokens", "palette", "scaffolding", "ai-agent", "llm", "mcp", "automation"],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js",
      "require": "./dist/*.cjs",
      "default": "./dist/*.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest run"
  },
  "dependencies": {
    "@iconify/utils": "^3.1.0",
    "opentype.js": "^1.3.4"
  },
  "devDependencies": {
    "@fetchkit/tsconfig": "workspace:*",
    "@types/opentype.js": "^1.3.9",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4"
  }
}
