{
  "name": "@fetchkit/seo",
  "version": "0.1.0",
  "description": "SEO artifact generator for developers and AI agents — meta tags, XML sitemaps, robots.txt, and Schema.org JSON-LD. Callable via REST API, MCP server, or direct import.",
  "license": "MIT",
  "repository": { "type": "git", "url": "https://github.com/smccart/fetchkit", "directory": "packages/seo" },
  "homepage": "https://fetchkit.dev",
  "keywords": ["seo", "meta-tags", "sitemap", "robots-txt", "json-ld", "schema-org", "scaffolding", "ai-agent", "llm", "mcp", "automation"],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js",
      "require": "./dist/*.cjs",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest run"
  },
  "devDependencies": {
    "@fetchkit/tsconfig": "workspace:*",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4"
  }
}
